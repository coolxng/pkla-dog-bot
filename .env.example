DISCORD_TOKEN=
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.1-8b-instant
OPENAI_API_KEY=
OPENAI_CHAT_FALLBACK=false
ENABLE_OPENAI_WEB_SEARCH=false
ENABLE_TRANSCRIPTION=false
ENABLE_LISTEN_IN=true

# Optional OpenAI-only feature settings
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_SEARCH_MODEL=chat-latest

# Optional local Piper text-to-speech settings
