PIPER_TTS_BINARY=piper

# Discord/server configuration
TARGET_CHANNEL_IDS=
OWNER_ID=
PING_MEMBERS_JSON=
EXTERNAL_CHANNEL_ID=
EXTERNAL_VOICE_CHANNEL_ID=1447148315312521256
EXTERNAL_SAY_CONTROL_TOKEN=

# Runtime / web server
PORT=3000
LOG_LEVEL=INFO
USE_PRODUCTION_WEB_SERVER=true
